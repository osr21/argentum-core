      },
      "receipts": [
        {
          "label": "in-progress",
          "action_ref": "sha256:a5bfa2dde39933a363c435d8035ee43898c5d7960b3d0de3230d940921a4259e",
          "state": "in-progress",
          "terminal": false,
          "issued_at": "2026-06-01T12:00:01.000Z"
        },
        {
          "label": "terminal",
          "action_ref": "sha256:a5bfa2dde39933a363c435d8035ee43898c5d7960b3d0de3230d940921a4259e",
          "state": "completed",
          "terminal": true,
          "issued_at": "2026-06-01T12:00:05.000Z"
        }
      ],
      "expected_result": "KNOWN_DESIGN_PROPERTY",
      "expected_error_code": null,
      "verifier_rule": "A verifier MUST NOT reject the shared action_ref as a collision or replay. To determine whether an action reached a terminal state, inspect the `terminal` field (or equivalent) in the signed receipt — not action_ref alone.",
      "rationale": "action_ref is state-agnostic by design. It identifies what action was claimed (who, what type, what scope, when) — not the execution outcome. Multiple receipts for the same action instance in different states are expected and correct. The signing layer (signing-trust-ref-v1) covers the full envelope including the terminal field, which is the authoritative signal for state. See docs/spec/action-ref.md §State vs Identity."
    },
