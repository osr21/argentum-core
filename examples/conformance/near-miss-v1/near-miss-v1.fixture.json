      "name": "same_action_ref_different_state",
      "failure_mode": "KNOWN_DESIGN_PROPERTY",
      "description": "Two receipts share the same preimage (agent_id, action_type, scope, timestamp) but differ in execution state — one in-progress, one terminal (completed). They produce the same action_ref. This is correct by spec: action_ref identifies the action, not the state of it. A verifier that treats the shared action_ref as a collision or replay MUST NOT reject on that basis alone.",
      "preimage_block": {
        "preimage": {
          "agent_id": "did:web:agent.example",
          "action_type": "task.execute",
          "scope": "mycelium:task:process_payment",
          "timestamp": "2026-06-01T12:00:00.000Z"
        },
        "canonical_bytes_utf8": "{\"action_type\":\"task.execute\",\"agent_id\":\"did:web:agent.example\",\"scope\":\"mycelium:task:process_payment\",\"timestamp\":\"2026-06-01T12:00:00.000Z\"}",
